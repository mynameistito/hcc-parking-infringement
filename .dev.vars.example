# Copy to .dev.vars for local wrangler dev (never commit .dev.vars)
#
# Generate a strong key, e.g. PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
API_KEY=replace-with-a-long-random-string

# Optional: allows POST /api/v1/sync without API_KEY
CRON_SECRET=replace-with-another-random-string

# Used by `bun run backfill` / `bun run sync` / `check-data`
# Production: https://hcc-parking-infringement.mynameistito.com
# Local Vite: http://localhost:5173  |  Wrangler: http://localhost:8787
# Tailscale Vite (`bun run dev:ts`): http://<your-tailscale-ip>:5173
WORKER_URL=http://localhost:8787

# Seed reads from R2 via S3 API when PARKING_STORE_READ_SOURCE=seed and no PARKING_SEED binding.
# Create in Dashboard → R2 → Manage R2 API Tokens (Object Read on hcc-parking-infringement-seed).
# R2_ACCESS_KEY_ID=...   (or R2_ACCESS_KEY=...)
# R2_SECRET_ACCESS_KEY=...
