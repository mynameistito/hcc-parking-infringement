{
  "name": "hcc-parking-infringement",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:wrangler": "bun run scripts/wrangler-dev.ts -- --watch",
    "dev:ts": "bun run scripts/dev-ts.ts",
    "deploy": "vite build && wrangler deploy -c dist/hcc_parking_infringement/wrangler.json --var PARKING_STORE_READ_SOURCE:seed --var FREE_TIER_MODE:true",
    "deploy:do": "vite build && wrangler deploy -c dist/hcc_parking_infringement/wrangler.json --var PARKING_STORE_READ_SOURCE:durable_object --var FREE_TIER_MODE:true",
    "deploy:seed": "vite build && wrangler deploy -c dist/hcc_parking_infringement/wrangler.json --var PARKING_STORE_READ_SOURCE:seed --var FREE_TIER_MODE:true",
    "enrich:seed-dashboard": "bun run scripts/enrich-seed-dashboard.ts",
    "migrate:seed-to-do": "bun run scripts/migrate-seed-to-do.ts",
    "build": "vite build",
    "typecheck": "tsgo --noEmit",
    "cf-typegen": "wrangler types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "vitest run",
    "daily:refresh": "bun run scripts/daily-refresh.ts",
    "backfill": "bun run scripts/backfill.ts",
    "push:local": "bun run scripts/push-local.ts",
    "push:json": "bun run scripts/push-json.ts",
    "seed:from-local": "bun run scripts/seed-from-local.ts",
    "seed:apply": "bun run scripts/seed-apply.ts",
    "export:json": "bun run scripts/export-json.ts",
    "import:json": "bun run scripts/import-json.ts",
    "import:csv": "bun run scripts/import-csv.ts",
    "sync": "bun run scripts/sync.ts",
    "geocode": "bun run scripts/geocode.ts",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/geojson": "^7946.0.16",
    "aws4fetch": "^1.0.20",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "hono": "^4.12.27",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.42.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-grab": "^0.1.47",
    "recharts": "3.8.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260624.1",
    "@vitejs/plugin-react": "^6.0.3",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "react-doctor": "^0.5.8",
    "ultracite": "^7.8.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
